# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv-2080/
venv/
.env
.python-version

# HF / torch local caches (never commit)
.cache/

# Large corpora (keep seed + manifests + schema in git)
datasets/raw/
datasets/processed/
datasets/latex_v1/
checkpoints/
!checkpoints/.gitkeep
*.pt
*.bin
*.safetensors
*.ckpt
wandb/
runs/

# Tokenizer train scratch — keep special_tokens + .gitkeep only
tokenizer/**/tmp/
tokenizer/**/*.log
tokenizer/**/tokenizer.model
tokenizer/**/vocab.json
tokenizer/**/checksum.sha256
tokenizer/**/meta.json
tokenizer/**/gate0_report*.json
!tokenizer/latex-v1/special_tokens.json
!tokenizer/latex-v1/.gitkeep

# IDE / OS
.idea/
.vscode/
.cursor/
*.swp
.DS_Store
Thumbs.db

# Secrets
*.pem
credentials.json
